{
  "description": "Windows Remote Desktop v2(by haku)",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": { "key_code": "left_control" },
      "to": [
        {
          "key_code": "left_control"
        }
      ],
      "to_if_alone": [{ "key_code": "escape" }],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "w",
        "modifiers": {
          "mandatory": ["control", "option"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "k",
          "modifiers": ["command", "shift"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "j",
        "modifiers": {
          "mandatory": ["option", "control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "left_arrow",
          "modifiers": ["command", "control"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "k",
        "modifiers": {
          "mandatory": ["option", "control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "right_arrow",
          "modifiers": ["command", "control"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "tab",
        "modifiers": {
          "mandatory": ["command"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "tab",
          "modifiers": ["option"]
        }
      ],
      "type": "basic"
    }
  ]
}
