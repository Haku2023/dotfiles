{
  "description": "System Ctrl v3(by haku)",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.github.wez.wezterm$",
            "^com.apple.systempreferences$",
            "^com.microsoft.VSCode$",
            "^com.google.Chrome.app.cmkncekebbebpfilplodngbpllndjkfo$",
            "^com.microsoft.rdc.macos$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "c",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "c",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.github.wez.wezterm$",
            "^com.apple.systempreferences$",
            "^com.microsoft.VSCode$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "v",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "v",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.github.wez.wezterm$",
            "^com.apple.systempreferences$",
            "^com.apple.finder$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "x",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "x",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.github.wez.wezterm$",
            "^com.apple.systempreferences$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "z",
        "modifiers": {
          "mandatory": ["control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "z",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.github.wez.wezterm$",
            "^com.apple.mail$",
            "^com.apple.iWork.Pages$",
            "^com.apple.iWork.Keynote$",
            "^com.apple.Preview$",
            "^com.apple.finder$",
            "^com.microsoft.rdc.macos$",
            "^com.google.Chrome.app.cmkncekebbebpfilplodngbpllndjkfo$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "h",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "delete_or_backspace",
          "modifiers": []
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.apple.Preview$"],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "n",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "down_arrow",
          "modifiers": []
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.apple.Preview$"],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "p",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "up_arrow",
          "modifiers": []
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com\\.microsoft\\.Word$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "f",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "right_arrow",
          "modifiers": []
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com\\.microsoft\\.Word$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "b",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "left_arrow",
          "modifiers": []
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com\\.microsoft\\.Word$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "a",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "left_arrow",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com\\.microsoft\\.Word$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "e",
        "modifiers": {
          "mandatory": ["left_control"],
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "right_arrow",
          "modifiers": ["left_command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.apple.iWork.Keynote$"],
          "type": "frontmost_application_if"
        },
        {
          "type": "expression_if",
          "expression": "L_control_expiration > system.now.milliseconds"
        }
      ],
      "from": {
        "key_code": "left_control",
        "modifiers": { "optional": [] }
      },
      "to": [
        {
          "set_notification_message": {
            "id": "my_message",
            "text": "Normal Mode!"
          }
        },
        {
          "set_variable": {
            "name": "keynote_vim",
            "value": 0
          }
        }
      ],
      "to_delayed_action": {
        "to_if_canceled": [
          {
            "set_notification_message": {
              "id": "my_message",
              "text": ""
            }
          }
        ],
        "to_if_invoked": [
          {
            "set_notification_message": {
              "id": "my_message",
              "text": ""
            }
          }
        ]
      },
      "to_if_alone": [{ "key_code": "escape" }],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.apple.iWork.Keynote$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "left_control",
        "modifiers": { "optional": [] }
      },
      "to": [
        {
          "set_variable": {
            "name": "L_control_expiration",
            "expression": "system.now.milliseconds + 300"
          }
        },
        {
          "key_code": "left_control",
          "lazy": true
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^com.apple.iWork.Pages$",
            "^com.apple.Notes$",
            "^org.pqrs.Karabiner-Elements.Settings$",
            "^com.apple.iWork.Numbers$",
            "^com.apple.iWork.Keynote$",
            "^com.apple.finder$",
            "^com.apple.Preview$",
            "^com.microsoft.rdc.macos$",
            "^com.google.Chrome.app.cmkncekebbebpfilplodngbpllndjkfo$"
          ],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "left_control",
        "modifiers": { "optional": [] }
      },
      "to": [
        {
          "key_code": "left_control",
          "lazy": true
        }
      ],
      "to_if_alone": [
        { "key_code": "escape" },
        {
          "set_notification_message": {
            "id": "my_message",
            "text": ""
          }
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.github.wez.wezterm$"],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "q",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "shell_command": "osascript -e 'tell application \"wezterm\" to activate' && sleep 0.3 && open -a wezterm"
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.github.wez.wezterm$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "q",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "key_code": "h",
          "modifiers": ["command"]
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": [],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "q",
        "modifiers": {
          "mandatory": ["control", "shift"],
          "optional": []
        }
      },
      "to": [
        {
          "shell_command": "open -a qutebrowser && osascript -e 'tell application \"qutebrowser\" to activate'"
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^org.mozilla.firefox$"],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "w",
        "modifiers": {
          "mandatory": ["control"],
          "optional": []
        }
      },
      "to": [
        {
          "shell_command": "osascript -e 'tell application \"Firefox\" to activate' && sleep 0.3 && open -a firefox"
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com.microsoft.rdc.macos$"],
          "type": "frontmost_application_unless"
        }
      ],
      "from": {
        "key_code": "w",
        "modifiers": {
          "mandatory": ["control", "shift"],
          "optional": []
        }
      },
      "to": [
        {
          "shell_command": "osascript -e 'tell application \"Windows App\" to activate' && sleep 0.3 && open -a \"Windows App\""
        }
      ],
      "type": "basic"
    }
  ]
}
